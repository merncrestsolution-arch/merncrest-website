# Local Docker (compose maps host 5434 → container 5432)
DATABASE_URL="postgresql://merncrest:merncrest@localhost:5434/merncrest?schema=public"

# Production / Vercel: Neon, Supabase, or Vercel Postgres
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/merncrest?sslmode=require"

AUTH_SECRET="generate-a-long-random-secret-for-production"
NEXT_PUBLIC_SITE_URL="https://merncrest.lk"
CONTACT_EMAIL="merncrestsolution@gmail.com"

# Payments — automatic gateways OFF by default (manual / bank transfer + admin verification)
PAYMENT_GATEWAY_ENABLED="false"
PAYMENT_DEMO_ENABLED="true"
BANK_NAME="Commercial Bank of Ceylon"
BANK_ACCOUNT_NAME="MernCrest Solutions (Pvt) Ltd"
BANK_ACCOUNT_NUMBER="1234567890"
BANK_BRANCH="Colombo"
# Dual bank accounts shown at checkout
BANK_COMMERCIAL_NAME="Commercial Bank of Ceylon"
BANK_COMMERCIAL_ACCOUNT_NAME="MernCrest Solutions (Pvt) Ltd"
BANK_COMMERCIAL_ACCOUNT_NUMBER="1234567890"
BANK_COMMERCIAL_BRANCH="Colombo"
BANK_PEOPLES_NAME="People's Bank"
BANK_PEOPLES_ACCOUNT_NAME="MernCrest Solutions (Pvt) Ltd"
BANK_PEOPLES_ACCOUNT_NUMBER="0987654321"
BANK_PEOPLES_BRANCH="Colombo Fort"

# PII encryption (AES-256-GCM). Prefer a dedicated 32+ char secret; falls back to AUTH_SECRET.
PII_ENCRYPTION_KEY=""

# PayHere (Sri Lanka) — enable with PAYMENT_GATEWAY_ENABLED=true
PAYHERE_MERCHANT_ID=""
PAYHERE_MERCHANT_SECRET=""
PAYHERE_SANDBOX="true"

# Namecheap (international domains) — whitelist server IP in Namecheap API panel
NAMECHEAP_API_USER=""
NAMECHEAP_API_KEY=""
NAMECHEAP_USERNAME=""
NAMECHEAP_CLIENT_IP=""
NAMECHEAP_SANDBOX="true"
# USD → LKR for wholesale estimate when live pricing not fetched
NAMECHEAP_USD_LKR_RATE="320"

# DomainLK / .lk reseller (RegisterHere, Green Line, etc. — after partnership)
DOMAINLK_API_URL=""
DOMAINLK_API_KEY=""
DOMAINLK_API_SECRET=""

# WhatsApp Cloud API (optional — webhook works in stub mode without these)
WHATSAPP_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_VERIFY_TOKEN="merncrest-verify"

BREVO_SMTP_HOST="smtp-relay.brevo.com"
BREVO_SMTP_PORT="587"
BREVO_SMTP_USER=""
BREVO_SMTP_PASS=""
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
NEXT_PUBLIC_GOOGLE_MAPS_KEY=""
