generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  passwordHash     String
  fullName         String
  company          String?
  /// CUSTOMER | STAFF | ADMIN | OWNER
  role             String    @default("CUSTOMER")
  emailVerifiedAt  DateTime?
  emailVerifyToken String?   @unique
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  sessions         Session[]
  profile          CustomerProfile?
  cart             Cart?
  orders           Order[]
  invoices         Invoice[]
  payments         Payment[]
  domains          Domain[]
  hostingAccounts  HostingAccount[]
  subscriptions    Subscription[]
  refundRequests   RefundRequest[]
  tickets          Ticket[]
  ticketMessages   TicketMessage[]
  notifications    Notification[]
  chatSessions     ChatSession[]
  crmLeadsOwned    CrmLead[]       @relation("LeadOwner")
  crmActivities   CrmActivity[]
  callbackRequests CallbackRequest[]

  @@index([role])
}

model CustomerProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  phone     String?
  address   String?
  city      String?
  country   String?  @default("Sri Lanka")
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  userAgent String?
  ip        String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model LoginHistory {
  id        String   @id @default(cuid())
  userId    String?
  email     String
  success   Boolean
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model Product {
  id            String   @id @default(cuid())
  slug          String   @unique
  name          String
  description   String
  category      String
  priceCents    Int
  currency      String   @default("LKR")
  /// ONCE | MONTHLY | YEARLY
  billingPeriod String   @default("ONCE")
  active        Boolean  @default(true)
  featured      Boolean  @default(false)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  cartItems  CartItem[]
  orderItems OrderItem[]

  @@index([category])
  @@index([active])
}

model Cart {
  id        String     @id @default(cuid())
  userId    String     @unique
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
  updatedAt DateTime   @updatedAt
  createdAt DateTime   @default(now())
}

model CartItem {
  id        String  @id @default(cuid())
  cartId    String
  cart      Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int     @default(1)
  /// JSON: domainName, tld, planCode, etc.
  metaJson  String?

  @@index([cartId])
}

model Order {
  id          String      @id @default(cuid())
  orderNumber String      @unique
  userId      String
  user        User        @relation(fields: [userId], references: [id])
  /// PENDING | PAID | PROCESSING | COMPLETED | CANCELLED
  status      String      @default("PENDING")
  subtotalCents Int
  taxCents      Int       @default(0)
  discountCents Int      @default(0)
  totalCents    Int
  currency      String    @default("LKR")
  couponCode    String?
  /// JSON registrant / billing contact snapshot
  registrantJson String?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  items           OrderItem[]
  invoice         Invoice?
  payments        Payment[]
  domains         Domain[]
  hostingAccounts HostingAccount[]
  subscriptions   Subscription[]
  refundRequests  RefundRequest[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id            String  @id @default(cuid())
  orderId       String
  order         Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId     String?
  product       Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  productName   String
  productSlug   String
  quantity      Int
  unitPriceCents Int
  totalCents    Int
  billingPeriod String  @default("ONCE")
  metaJson      String?
}

model Invoice {
  id            String    @id @default(cuid())
  invoiceNumber String    @unique
  orderId       String    @unique
  order         Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  /// DRAFT | SENT | PAID | OVERDUE | VOID
  status        String    @default("SENT")
  subtotalCents Int
  taxCents      Int       @default(0)
  totalCents    Int
  currency      String    @default("LKR")
  dueAt         DateTime?
  paidAt        DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  payments Payment[]

  @@index([userId])
  @@index([status])
}

model Payment {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  invoiceId   String?
  invoice     Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  amountCents Int
  currency    String   @default("LKR")
  /// MANUAL | DEMO | PAYHERE | STRIPE
  method      String   @default("DEMO")
  /// PENDING | SUCCEEDED | FAILED
  status      String   @default("PENDING")
  providerRef String?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([orderId])
  @@index([status])
}

model Domain {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id])
  orderId      String?
  order        Order?    @relation(fields: [orderId], references: [id], onDelete: SetNull)
  name         String
  tld          String
  /// PENDING | ACTIVE | EXPIRED | TRANSFERRING | LOCKED
  status       String    @default("PENDING")
  autoRenew    Boolean   @default(true)
  locked       Boolean   @default(false)
  registeredAt DateTime?
  expiresAt    DateTime?
  nameservers  String    @default("ns1.merncrest.lk,ns2.merncrest.lk")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  dnsRecords DnsRecord[]

  @@unique([name, tld])
  @@index([userId])
  @@index([status])
  @@index([expiresAt])
}

model DnsRecord {
  id        String   @id @default(cuid())
  domainId  String
  domain    Domain   @relation(fields: [domainId], references: [id], onDelete: Cascade)
  /// A | AAAA | CNAME | MX | TXT | NS
  type      String
  host      String
  value     String
  ttl       Int      @default(3600)
  priority  Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([domainId])
}

model HostingAccount {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  orderId       String?
  order         Order?    @relation(fields: [orderId], references: [id], onDelete: SetNull)
  label         String
  planCode      String
  /// PENDING | PROVISIONING | ACTIVE | SUSPENDED | CANCELLED
  status        String    @default("PENDING")
  primaryDomain String?
  diskMb        Int       @default(10240)
  diskUsedMb    Int       @default(0)
  bandwidthGb   Int       @default(100)
  bandwidthUsedGb Int     @default(0)
  cpuPercent    Int       @default(5)
  ramMb         Int       @default(512)
  ramUsedMb     Int       @default(128)
  sslStatus     String    @default("PENDING")
  backupStatus  String    @default("OK")
  panelUrl      String?
  activatedAt   DateTime?
  renewsAt      DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId])
  @@index([status])
}

model Subscription {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  orderId       String?
  order         Order?    @relation(fields: [orderId], references: [id], onDelete: SetNull)
  productSlug   String
  productName   String
  /// ACTIVE | PAST_DUE | CANCELLED | PAUSED
  status        String    @default("ACTIVE")
  /// MONTHLY | YEARLY
  billingPeriod String
  amountCents   Int
  currency      String    @default("LKR")
  nextBillingAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId])
  @@index([status])
  @@index([nextBillingAt])
}

model Coupon {
  id              String    @id @default(cuid())
  code            String    @unique
  /// PERCENT | FIXED
  type            String
  value           Int
  maxUses         Int?
  usedCount       Int       @default(0)
  minOrderCents   Int       @default(0)
  active          Boolean   @default(true)
  expiresAt       DateTime?
  createdAt       DateTime  @default(now())
}

model RefundRequest {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  amountCents Int
  reason      String
  /// PENDING | APPROVED | REJECTED | PAID
  status      String   @default("PENDING")
  adminNote   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

/// Support ticket (portal + admin + chat/WhatsApp escalation)
model Ticket {
  id           String   @id @default(cuid())
  ticketNumber String   @unique
  userId       String?
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  /// Guest contact when not logged in
  guestEmail   String?
  guestName    String?
  subject      String
  /// BILLING | TECHNICAL | SALES | DOMAIN | HOSTING | GENERAL
  department   String   @default("GENERAL")
  /// LOW | MEDIUM | HIGH | URGENT
  priority     String   @default("MEDIUM")
  /// OPEN | IN_PROGRESS | WAITING | RESOLVED | CLOSED
  status       String   @default("OPEN")
  /// PORTAL | LIVE_CHAT | WHATSAPP | EMAIL | PHONE | IVR
  channel      String   @default("PORTAL")
  assigneeName String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  closedAt     DateTime?

  messages TicketMessage[]

  @@index([userId])
  @@index([status])
  @@index([department])
  @@index([createdAt])
}

model TicketMessage {
  id         String   @id @default(cuid())
  ticketId   String
  ticket     Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId   String?
  author     User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  authorName String
  /// CUSTOMER | STAFF | SYSTEM | AI
  authorRole String   @default("CUSTOMER")
  body       String
  internal   Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([ticketId])
  @@index([createdAt])
}

/// Sales / support CRM lead
model CrmLead {
  id          String    @id @default(cuid())
  /// NEW | CONTACTED | QUALIFIED | PROPOSAL | WON | LOST
  stage       String    @default("NEW")
  source      String    @default("WEBSITE")
  fullName    String
  email       String
  phone       String?
  company     String?
  interest    String?
  notes       String?
  valueCents  Int       @default(0)
  ownerId     String?
  owner       User?     @relation("LeadOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  activities CrmActivity[]

  @@index([stage])
  @@index([email])
  @@index([ownerId])
}

model CrmActivity {
  id        String   @id @default(cuid())
  leadId    String?
  lead      CrmLead? @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  /// NOTE | CALL | EMAIL | WHATSAPP | MEETING | STATUS
  type      String   @default("NOTE")
  body      String
  createdAt DateTime @default(now())

  @@index([leadId])
  @@index([createdAt])
}

model ChatSession {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  visitorId   String
  locale      String   @default("en")
  /// OPEN | HANDOFF | CLOSED
  status      String   @default("OPEN")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  messages ChatMessage[]

  @@index([userId])
  @@index([visitorId])
  @@index([status])
}

model ChatMessage {
  id        String      @id @default(cuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  /// USER | AI | AGENT | SYSTEM
  role      String
  body      String
  createdAt DateTime    @default(now())

  @@index([sessionId])
}

/// WhatsApp Business API message log (webhook stub)
model WhatsAppMessage {
  id          String   @id @default(cuid())
  waId        String?
  direction   String
  /// IN | OUT
  phone       String
  body        String
  /// RECEIVED | SENT | FAILED | AI_REPLIED
  status      String   @default("RECEIVED")
  localeHint  String?
  metaJson    String?
  createdAt   DateTime @default(now())

  @@index([phone])
  @@index([createdAt])
}

/// IVR / phone callback queue
model CallbackRequest {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  fullName    String
  phone       String
  email       String?
  /// SALES | SUPPORT | BILLING | TECHNICAL
  reason      String   @default("SUPPORT")
  preferredAt String?
  notes       String?
  /// PENDING | SCHEDULED | COMPLETED | CANCELLED
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  body      String
  /// SYSTEM | BILLING | SUPPORT | ORDER | SECURITY
  category  String   @default("SYSTEM")
  href      String?
  readAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([readAt])
  @@index([createdAt])
}
