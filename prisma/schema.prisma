generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  passwordHash     String
  fullName         String
  company          String?
  /// CUSTOMER | STAFF | ADMIN | OWNER
  role             String    @default("CUSTOMER")
  emailVerifiedAt  DateTime?
  emailVerifyToken String?   @unique
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  sessions         Session[]
  profile          CustomerProfile?
  cart             Cart?
  orders           Order[]
  invoices         Invoice[]
  payments         Payment[]
  domains          Domain[]
  hostingAccounts  HostingAccount[]
  subscriptions    Subscription[]
  refundRequests   RefundRequest[]

  @@index([role])
}

model CustomerProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  phone     String?
  address   String?
  city      String?
  country   String?  @default("Sri Lanka")
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  userAgent String?
  ip        String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model LoginHistory {
  id        String   @id @default(cuid())
  userId    String?
  email     String
  success   Boolean
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model Product {
  id            String   @id @default(cuid())
  slug          String   @unique
  name          String
  description   String
  category      String
  priceCents    Int
  currency      String   @default("LKR")
  /// ONCE | MONTHLY | YEARLY
  billingPeriod String   @default("ONCE")
  active        Boolean  @default(true)
  featured      Boolean  @default(false)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  cartItems  CartItem[]
  orderItems OrderItem[]

  @@index([category])
  @@index([active])
}

model Cart {
  id        String     @id @default(cuid())
  userId    String     @unique
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
  updatedAt DateTime   @updatedAt
  createdAt DateTime   @default(now())
}

model CartItem {
  id        String  @id @default(cuid())
  cartId    String
  cart      Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int     @default(1)
  /// JSON: domainName, tld, planCode, etc.
  metaJson  String?

  @@index([cartId])
}

model Order {
  id          String      @id @default(cuid())
  orderNumber String      @unique
  userId      String
  user        User        @relation(fields: [userId], references: [id])
  /// PENDING | PAID | PROCESSING | COMPLETED | CANCELLED
  status      String      @default("PENDING")
  subtotalCents Int
  taxCents      Int       @default(0)
  discountCents Int      @default(0)
  totalCents    Int
  currency      String    @default("LKR")
  couponCode    String?
  /// JSON registrant / billing contact snapshot
  registrantJson String?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  items           OrderItem[]
  invoice         Invoice?
  payments        Payment[]
  domains         Domain[]
  hostingAccounts HostingAccount[]
  subscriptions   Subscription[]
  refundRequests  RefundRequest[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id            String  @id @default(cuid())
  orderId       String
  order         Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId     String?
  product       Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  productName   String
  productSlug   String
  quantity      Int
  unitPriceCents Int
  totalCents    Int
  billingPeriod String  @default("ONCE")
  metaJson      String?
}

model Invoice {
  id            String    @id @default(cuid())
  invoiceNumber String    @unique
  orderId       String    @unique
  order         Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  /// DRAFT | SENT | PAID | OVERDUE | VOID
  status        String    @default("SENT")
  subtotalCents Int
  taxCents      Int       @default(0)
  totalCents    Int
  currency      String    @default("LKR")
  dueAt         DateTime?
  paidAt        DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  payments Payment[]

  @@index([userId])
  @@index([status])
}

model Payment {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  invoiceId   String?
  invoice     Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  amountCents Int
  currency    String   @default("LKR")
  /// MANUAL | DEMO | PAYHERE | STRIPE
  method      String   @default("DEMO")
  /// PENDING | SUCCEEDED | FAILED
  status      String   @default("PENDING")
  providerRef String?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([orderId])
  @@index([status])
}

model Domain {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id])
  orderId      String?
  order        Order?    @relation(fields: [orderId], references: [id], onDelete: SetNull)
  name         String
  tld          String
  /// PENDING | ACTIVE | EXPIRED | TRANSFERRING | LOCKED
  status       String    @default("PENDING")
  autoRenew    Boolean   @default(true)
  locked       Boolean   @default(false)
  registeredAt DateTime?
  expiresAt    DateTime?
  nameservers  String    @default("ns1.merncrest.lk,ns2.merncrest.lk")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  dnsRecords DnsRecord[]

  @@unique([name, tld])
  @@index([userId])
  @@index([status])
  @@index([expiresAt])
}

model DnsRecord {
  id        String   @id @default(cuid())
  domainId  String
  domain    Domain   @relation(fields: [domainId], references: [id], onDelete: Cascade)
  /// A | AAAA | CNAME | MX | TXT | NS
  type      String
  host      String
  value     String
  ttl       Int      @default(3600)
  priority  Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([domainId])
}

model HostingAccount {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  orderId       String?
  order         Order?    @relation(fields: [orderId], references: [id], onDelete: SetNull)
  label         String
  planCode      String
  /// PENDING | PROVISIONING | ACTIVE | SUSPENDED | CANCELLED
  status        String    @default("PENDING")
  primaryDomain String?
  diskMb        Int       @default(10240)
  diskUsedMb    Int       @default(0)
  bandwidthGb   Int       @default(100)
  bandwidthUsedGb Int     @default(0)
  cpuPercent    Int       @default(5)
  ramMb         Int       @default(512)
  ramUsedMb     Int       @default(128)
  sslStatus     String    @default("PENDING")
  backupStatus  String    @default("OK")
  panelUrl      String?
  activatedAt   DateTime?
  renewsAt      DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId])
  @@index([status])
}

model Subscription {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  orderId       String?
  order         Order?    @relation(fields: [orderId], references: [id], onDelete: SetNull)
  productSlug   String
  productName   String
  /// ACTIVE | PAST_DUE | CANCELLED | PAUSED
  status        String    @default("ACTIVE")
  /// MONTHLY | YEARLY
  billingPeriod String
  amountCents   Int
  currency      String    @default("LKR")
  nextBillingAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId])
  @@index([status])
  @@index([nextBillingAt])
}

model Coupon {
  id              String    @id @default(cuid())
  code            String    @unique
  /// PERCENT | FIXED
  type            String
  value           Int
  maxUses         Int?
  usedCount       Int       @default(0)
  minOrderCents   Int       @default(0)
  active          Boolean   @default(true)
  expiresAt       DateTime?
  createdAt       DateTime  @default(now())
}

model RefundRequest {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  amountCents Int
  reason      String
  /// PENDING | APPROVED | REJECTED | PAID
  status      String   @default("PENDING")
  adminNote   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([status])
}
