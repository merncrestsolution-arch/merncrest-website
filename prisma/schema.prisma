generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  passwordHash     String
  fullName         String
  company          String?
  /// CUSTOMER | STAFF | ADMIN | OWNER
  role             String    @default("CUSTOMER")
  emailVerifiedAt  DateTime?
  emailVerifyToken String?   @unique
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  sessions         Session[]
  profile          CustomerProfile?
  cart             Cart?
  orders           Order[]
  invoices         Invoice[]
  payments         Payment[]
  domains          Domain[]
  hostingAccounts  HostingAccount[]
  subscriptions    Subscription[]
  refundRequests   RefundRequest[]
  tickets          Ticket[]
  ticketMessages   TicketMessage[]
  notifications    Notification[]
  chatSessions     ChatSession[]
  crmLeadsOwned    CrmLead[]       @relation("LeadOwner")
  crmActivities   CrmActivity[]
  callbackRequests CallbackRequest[]
  quotations       Quotation[]
  callRecords      CallRecord[]
  employee         Employee?
  leaveRequests    LeaveRequest[]  @relation("LeaveEmployee")
  leaveApprovals   LeaveRequest[]  @relation("LeaveApprover")
  projectMembers   ProjectMember[]
  tasksAssigned    ProjectTask[]   @relation("TaskAssignee")
  financeEntries   FinanceEntry[]
  permissions      StaffPermission[]
  workOrders       WorkOrder[]     @relation("WorkOrderAssignee")
  attendance       AttendanceRecord[]
  documents        Document[]      @relation("DocUploader")
  internalMessages InternalMessage[] @relation("MsgSender")
  vendorsManaged   Vendor[]        @relation("VendorOwner")
  activities       CustomerActivity[]
  downloads        CustomerDownload[]

  @@index([role])
}

model CustomerProfile {
  id                 String   @id @default(cuid())
  userId             String   @unique
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Public unique customer ID e.g. MC-A1B2C3
  customerCode       String?  @unique
  photoUrl           String?
  phone              String?
  whatsapp           String?
  address            String?
  city               String?
  province           String?
  postalCode         String?
  country            String?  @default("Sri Lanka")
  /// Encrypted at rest (AES-256-GCM) — see lib/security/pii.ts. Retention: policy TBD (PDPA).
  businessReg        String?
  /// Encrypted at rest (AES-256-GCM) — see lib/security/pii.ts. Retention: policy TBD (PDPA).
  nicPassport        String?
  timezone           String?  @default("Asia/Colombo")
  preferredLanguage  String?  @default("en")
  /// Communication preferences
  notifyEmail        Boolean  @default(true)
  notifyWhatsApp     Boolean  @default(true)
  notifySms          Boolean  @default(false)
  marketingOptIn     Boolean  @default(false)
  /// Assigned staff (Customer 360)
  assignedSalesId    String?
  assignedSupportId  String?
  /// GOOD | AVERAGE | AT_RISK | VIP
  customerRating     String?  @default("GOOD")
  creditBalanceCents Int      @default(0)
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

/// Portal / CRM-linked customer activity trail
model CustomerActivity {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// ORDER | PAYMENT | TICKET | DOMAIN | HOSTING | LOGIN | PROFILE | SYSTEM
  category  String   @default("SYSTEM")
  title     String
  body      String?
  href      String?
  metaJson  String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@index([category])
}

/// Platform announcements shown on customer portal dashboard
model Announcement {
  id        String    @id @default(cuid())
  title     String
  body      String
  /// INFO | WARNING | SUCCESS | PROMO
  tone      String    @default("INFO")
  href      String?
  active    Boolean   @default(true)
  startsAt  DateTime  @default(now())
  endsAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([active])
  @@index([startsAt])
}

/// Customer downloadable assets (invoices PDF links, licenses, manuals)
model CustomerDownload {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Global assets when userId is null
  title       String
  description String?
  /// INVOICE | RECEIPT | LICENSE | MANUAL | SOFTWARE | DOCUMENT
  category    String   @default("DOCUMENT")
  fileUrl     String
  fileType    String?  @default("PDF")
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([category])
  @@index([active])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  userAgent String?
  ip        String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model LoginHistory {
  id        String   @id @default(cuid())
  userId    String?
  email     String
  success   Boolean
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

/// Third-party reseller provider (domains, hosting, VPS, SSL, email, cloud).
/// MernCrest does NOT own hosting infrastructure — services are purchased via Provider APIs.
model Provider {
  id                 String    @id @default(cuid())
  name               String
  /// Stable code e.g. mock-a | provider-b
  code               String    @unique
  /// DOMAIN | HOSTING | SSL | EMAIL | CLOUD | MULTI
  providerType       String    @default("MULTI")
  apiUrl             String?
  apiKey             String?
  apiSecret          String?
  /// JSON array: ["domains","hosting","vps","ssl","email","cloud"]
  supportedServices  String    @default("[]")
  /// ACTIVE | INACTIVE | ERROR
  status             String    @default("ACTIVE")
  /// Lower = higher priority when routing
  priority           Int       @default(100)
  /// IDLE | SYNCING | SUCCESS | FAILED
  syncStatus         String    @default("IDLE")
  lastSyncedAt       DateTime?
  /// Fallback fixed margin (cents) when category margin missing
  defaultMarginCents Int       @default(0)
  notes              String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  products        Product[]
  domains         Domain[]
  hostingAccounts HostingAccount[]

  @@index([status])
  @@index([priority])
}

/// Configurable profit margins by product category.
/// Selling Price = Provider Price + Margin (fixed and/or percent).
model PricingMargin {
  id            String   @id @default(cuid())
  /// domains | hosting | vps | ssl | email | cloud
  category      String   @unique
  marginCents   Int      @default(0)
  marginPercent Float    @default(0)
  /// FIXED | PERCENT | BOTH — FIXED uses marginCents; PERCENT uses marginPercent; BOTH adds both.
  /// Existing rows keep FIXED (do not silently change stored values). New USD products default to PERCENT.
  marginMode    String   @default("FIXED")
  /// Extra % on FX conversion (USD→LKR) to absorb rate movement between quote and purchase
  fxBufferPercent Float  @default(2)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Product {
  id                 String    @id @default(cuid())
  slug               String    @unique
  name               String
  description        String
  category           String
  /// Public selling price (provider cost + margin)
  priceCents         Int
  /// Internal provider cost (hidden from customer invoices)
  providerPriceCents Int?
  currency           String    @default("LKR")
  /// ONCE | MONTHLY | YEARLY
  billingPeriod      String    @default("ONCE")
  active             Boolean   @default(true)
  featured           Boolean   @default(false)
  sortOrder          Int       @default(0)
  providerId         String?
  provider           Provider? @relation(fields: [providerId], references: [id], onDelete: SetNull)
  /// External SKU / package id at the provider
  providerProductId  String?
  /// Admin marketing overrides (public catalog still uses name/description as fallback)
  marketingTitle     String?
  marketingBanner    String?
  marketingBody      String?
  /// JSON package specs synced from provider
  specsJson          String?
  lastSyncedAt       DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  cartItems  CartItem[]
  orderItems OrderItem[]

  @@index([category])
  @@index([active])
  @@index([providerId])
}

model Cart {
  id        String     @id @default(cuid())
  userId    String     @unique
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
  updatedAt DateTime   @updatedAt
  createdAt DateTime   @default(now())
}

model CartItem {
  id        String  @id @default(cuid())
  cartId    String
  cart      Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int     @default(1)
  /// JSON: domainName, tld, planCode, etc.
  metaJson  String?
  /// Provider wholesale currency at quote (USD | LKR)
  providerCurrency     String?
  /// Locked USD→LKR rate at quote time (units of LKR per 1 USD)
  exchangeRate         Float?
  exchangeRateLockedAt DateTime?
  fxBufferPercent      Float?

  @@index([cartId])
}

model Order {
  id          String      @id @default(cuid())
  orderNumber String      @unique
  userId      String
  user        User        @relation(fields: [userId], references: [id])
  /// DRAFT | PENDING | WAITING_PAYMENT | PAID | PROCESSING | PROVISIONING | PROVISIONING_FAILED | COMPLETED | CANCELLED | REFUNDED
  status      String      @default("PENDING")
  subtotalCents Int
  taxCents      Int       @default(0)
  discountCents Int      @default(0)
  totalCents    Int
  currency      String    @default("LKR")
  couponCode    String?
  /// JSON registrant / billing contact snapshot
  registrantJson String?
  notes         String?
  /// Auto-provision retry counter (max 3 per activateOrderServices run)
  provisioningAttempts Int @default(0)
  lastProvisionError   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  items           OrderItem[]
  invoice         Invoice?
  payments        Payment[]
  domains         Domain[]
  hostingAccounts HostingAccount[]
  subscriptions   Subscription[]
  refundRequests  RefundRequest[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id                 String   @id @default(cuid())
  orderId            String
  order              Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId          String?
  product            Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  productName        String
  productSlug        String
  quantity           Int
  unitPriceCents     Int
  totalCents         Int
  /// Internal provider cost snapshot in selling currency (LKR cents after FX)
  providerCostCents  Int?
  /// Original provider currency before FX (USD | LKR)
  providerCurrency     String?
  /// Locked USD→LKR rate used for this line
  exchangeRate         Float?
  exchangeRateLockedAt DateTime?
  fxBufferPercent      Float?
  billingPeriod      String   @default("ONCE")
  metaJson           String?
}

model Invoice {
  id            String    @id @default(cuid())
  invoiceNumber String    @unique
  orderId       String    @unique
  order         Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  /// DRAFT | SENT | PAID | OVERDUE | VOID
  status        String    @default("SENT")
  subtotalCents Int
  taxCents      Int       @default(0)
  totalCents    Int
  currency      String    @default("LKR")
  dueAt         DateTime?
  paidAt        DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  payments Payment[]

  @@index([userId])
  @@index([status])
}

model Payment {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id])
  orderId      String
  order        Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  invoiceId    String?
  invoice      Invoice?  @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  amountCents  Int
  currency     String    @default("LKR")
  /// MANUAL | BANK_TRANSFER | DEMO | PAYHERE | STRIPE
  method       String    @default("MANUAL")
  /// PENDING | AWAITING_VERIFICATION | SUCCEEDED | FAILED | REJECTED
  status       String    @default("PENDING")
  providerRef  String?
  /// Bank transfer reference / customer note (legacy — prefer referenceNumber)
  proofNote    String?
  /// Bank transfer reference number (required for new submissions)
  referenceNumber String?
  /// Receipt / screenshot URL (required for new bank-transfer submissions)
  proofImageUrl   String?
  adminNote    String?
  verifiedById String?
  verifiedAt   DateTime?
  createdAt    DateTime  @default(now())

  @@index([userId])
  @@index([orderId])
  @@index([status])
  @@index([createdAt])
}

model Domain {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id])
  orderId      String?
  order        Order?    @relation(fields: [orderId], references: [id], onDelete: SetNull)
  providerId   String?
  provider     Provider? @relation(fields: [providerId], references: [id], onDelete: SetNull)
  /// External registration id at the provider
  providerRef  String?
  name         String
  tld          String
  /// PENDING | ACTIVE | EXPIRED | TRANSFERRING | LOCKED
  status       String    @default("PENDING")
  autoRenew    Boolean   @default(true)
  locked       Boolean   @default(false)
  registeredAt DateTime?
  expiresAt    DateTime?
  /// Reseller nameservers (provider-managed; not MernCrest-owned infra)
  nameservers  String    @default("ns1.provider.example,ns2.provider.example")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  dnsRecords DnsRecord[]

  @@unique([name, tld])
  @@index([userId])
  @@index([status])
  @@index([expiresAt])
  @@index([providerId])
}

model DnsRecord {
  id        String   @id @default(cuid())
  domainId  String
  domain    Domain   @relation(fields: [domainId], references: [id], onDelete: Cascade)
  /// A | AAAA | CNAME | MX | TXT | NS
  type      String
  host      String
  value     String
  ttl       Int      @default(3600)
  priority  Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([domainId])
}

model HostingAccount {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id])
  orderId         String?
  order           Order?    @relation(fields: [orderId], references: [id], onDelete: SetNull)
  providerId      String?
  provider        Provider? @relation(fields: [providerId], references: [id], onDelete: SetNull)
  /// External account id at the provider
  providerRef     String?
  label           String
  planCode        String
  /// PENDING | PROVISIONING | ACTIVE | SUSPENDED | CANCELLED
  status          String    @default("PENDING")
  primaryDomain   String?
  diskMb          Int       @default(10240)
  diskUsedMb      Int       @default(0)
  bandwidthGb     Int       @default(100)
  bandwidthUsedGb Int       @default(0)
  cpuPercent      Int       @default(5)
  ramMb           Int       @default(512)
  ramUsedMb       Int       @default(128)
  sslStatus       String    @default("PENDING")
  backupStatus    String    @default("OK")
  /// Provider control panel URL (not MernCrest-owned servers)
  panelUrl        String?
  activatedAt     DateTime?
  renewsAt        DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([userId])
  @@index([status])
  @@index([providerId])
}

model Subscription {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  orderId       String?
  order         Order?    @relation(fields: [orderId], references: [id], onDelete: SetNull)
  productSlug   String
  productName   String
  /// ACTIVE | PAST_DUE | CANCELLED | PAUSED
  status        String    @default("ACTIVE")
  /// MONTHLY | YEARLY
  billingPeriod String
  amountCents   Int
  currency      String    @default("LKR")
  nextBillingAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId])
  @@index([status])
  @@index([nextBillingAt])
}

model Coupon {
  id              String    @id @default(cuid())
  code            String    @unique
  /// PERCENT | FIXED
  type            String
  value           Int
  maxUses         Int?
  usedCount       Int       @default(0)
  minOrderCents   Int       @default(0)
  active          Boolean   @default(true)
  expiresAt       DateTime?
  createdAt       DateTime  @default(now())
}

model RefundRequest {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  amountCents Int
  reason      String
  /// PENDING | APPROVED | REJECTED | PAID
  status      String   @default("PENDING")
  adminNote   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

/// Support ticket (portal + admin + chat/WhatsApp escalation)
model Ticket {
  id           String   @id @default(cuid())
  ticketNumber String   @unique
  userId       String?
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  /// Guest contact when not logged in
  guestEmail   String?
  guestName    String?
  subject      String
  /// BILLING | TECHNICAL | SALES | DOMAIN | HOSTING | GENERAL | ENTERPRISE
  department   String   @default("GENERAL")
  /// LOW | MEDIUM | HIGH | URGENT
  priority     String   @default("MEDIUM")
  /// OPEN | IN_PROGRESS | WAITING | RESOLVED | CLOSED
  status       String   @default("OPEN")
  /// PORTAL | LIVE_CHAT | WHATSAPP | EMAIL | PHONE | IVR
  channel      String   @default("PORTAL")
  assigneeName String?
  csatRating   Int?
  csatFeedback String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  closedAt     DateTime?

  messages TicketMessage[]

  @@index([userId])
  @@index([status])
  @@index([department])
  @@index([createdAt])
}

model TicketMessage {
  id         String   @id @default(cuid())
  ticketId   String
  ticket     Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId   String?
  author     User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  authorName String
  /// CUSTOMER | STAFF | SYSTEM | AI
  authorRole String   @default("CUSTOMER")
  body       String
  internal   Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([ticketId])
  @@index([createdAt])
}

/// Sales / support CRM lead
model CrmLead {
  id          String    @id @default(cuid())
  leadNumber  String?   @unique
  /// NEW | ASSIGNED | QUALIFIED | MEETING | QUOTATION | NEGOTIATION | WON | LOST | ON_HOLD
  /// Legacy CONTACTED was migrated to QUALIFIED (see scripts/migrate-crm-contacted.ts)
  stage       String    @default("NEW")
  source      String    @default("WEBSITE")
  fullName    String
  email       String
  phone       String?
  company     String?
  interest    String?
  notes       String?
  valueCents  Int       @default(0)
  budgetCents Int       @default(0)
  /// LOW | MEDIUM | HIGH | URGENT
  priority    String    @default("MEDIUM")
  /// 0–100 lead score
  leadScore   Int       @default(0)
  timeline    String?
  followUpAt  DateTime?
  ownerId     String?
  owner       User?     @relation("LeadOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  activities  CrmActivity[]
  quotations  Quotation[]
  followUps   CrmFollowUp[]
  meetings    CrmMeeting[]

  @@index([stage])
  @@index([email])
  @@index([ownerId])
  @@index([followUpAt])
  @@index([leadScore])
}

model CrmActivity {
  id        String   @id @default(cuid())
  leadId    String?
  lead      CrmLead? @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  /// NOTE | CALL | EMAIL | WHATSAPP | MEETING | STATUS | CHAT | IVR | FORM
  type      String   @default("NOTE")
  body      String
  /// Optional channel link e.g. whatsapp message id
  channelRef String?
  createdAt DateTime @default(now())

  @@index([leadId])
  @@index([createdAt])
}

model CrmFollowUp {
  id          String    @id @default(cuid())
  leadId      String
  lead        CrmLead   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  assigneeId  String?
  /// CALL | WHATSAPP | EMAIL | MEETING | DEMO | REMINDER | ESCALATION
  type        String    @default("CALL")
  title       String
  notes       String?
  dueAt       DateTime
  /// PENDING | DONE | OVERDUE | CANCELLED
  status      String    @default("PENDING")
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([leadId])
  @@index([dueAt])
  @@index([status])
}

model CrmMeeting {
  id          String    @id @default(cuid())
  leadId      String?
  lead        CrmLead?  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId      String?
  /// CONSULTATION | ONLINE | OFFICE | TECHNICAL | SALES
  meetingType String    @default("CONSULTATION")
  title       String
  location    String?
  scheduledAt DateTime
  durationMin Int       @default(30)
  /// SCHEDULED | COMPLETED | CANCELLED | NO_SHOW
  status      String    @default("SCHEDULED")
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([leadId])
  @@index([scheduledAt])
  @@index([status])
}

/// CSAT / NPS after ticket, call, meeting, project
model CustomerSatisfaction {
  id          String   @id @default(cuid())
  userId      String?
  leadId      String?
  /// TICKET | CALL | MEETING | PROJECT | CHAT | GENERAL
  channel     String   @default("GENERAL")
  referenceId String?
  rating      Int
  /// 0–10 NPS
  npsScore    Int?
  feedback    String?
  suggestions String?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([channel])
  @@index([createdAt])
}

model ChatSession {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  visitorId   String
  locale      String   @default("en")
  /// Sales | Technical | Hosting | Billing | Domain | Enterprise
  department  String?
  /// OPEN | HANDOFF | CLOSED
  status      String   @default("OPEN")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  messages ChatMessage[]

  @@index([userId])
  @@index([visitorId])
  @@index([status])
}

model ChatMessage {
  id        String      @id @default(cuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  /// USER | AI | AGENT | SYSTEM
  role      String
  body      String
  createdAt DateTime    @default(now())

  @@index([sessionId])
}

/// WhatsApp Business API message log (webhook stub)
model WhatsAppMessage {
  id          String   @id @default(cuid())
  waId        String?
  direction   String
  /// IN | OUT
  phone       String
  body        String
  /// RECEIVED | SENT | FAILED | AI_REPLIED
  status      String   @default("RECEIVED")
  localeHint  String?
  metaJson    String?
  createdAt   DateTime @default(now())

  @@index([phone])
  @@index([createdAt])
}

/// IVR / phone callback queue
model CallbackRequest {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  fullName    String
  phone       String
  email       String?
  /// SALES | SUPPORT | BILLING | TECHNICAL
  reason      String   @default("SUPPORT")
  preferredAt String?
  notes       String?
  /// PENDING | SCHEDULED | COMPLETED | CANCELLED
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  body      String
  /// SYSTEM | BILLING | SUPPORT | ORDER | SECURITY
  category  String   @default("SYSTEM")
  href      String?
  readAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([readAt])
  @@index([createdAt])
}

model Quotation {
  id            String   @id @default(cuid())
  quoteNumber   String   @unique
  leadId        String?
  lead          CrmLead? @relation(fields: [leadId], references: [id], onDelete: SetNull)
  userId        String?
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  /// DRAFT | SENT | ACCEPTED | REJECTED | CHANGES_REQUESTED | EXPIRED
  status        String   @default("DRAFT")
  customerName  String
  customerEmail String
  company       String?
  subtotalCents Int
  taxCents      Int      @default(0)
  discountCents Int      @default(0)
  totalCents    Int
  currency      String   @default("LKR")
  validUntil    DateTime?
  terms         String?
  notes         String?
  orderId       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  items QuotationItem[]

  @@index([leadId])
  @@index([userId])
  @@index([status])
}

model QuotationItem {
  id             String    @id @default(cuid())
  quotationId    String
  quotation      Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  description    String
  quantity       Int       @default(1)
  unitPriceCents Int
  totalCents     Int
}

/// IVR / landline call log
model CallRecord {
  id           String   @id @default(cuid())
  callNumber   String   @unique
  userId       String?
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  phone        String
  /// si | ta | en
  language     String   @default("en")
  /// SALES | TECHNICAL | HOSTING | DOMAIN | BILLING | ENTERPRISE | CARE
  department   String   @default("CARE")
  agentName    String?
  /// RINGING | ANSWERED | MISSED | VOICEMAIL | CALLBACK
  status       String   @default("MISSED")
  durationSec  Int      @default(0)
  recordingUrl String?
  notes        String?
  disposition  String?
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([status])
  @@index([department])
  @@index([createdAt])
}

/// —— Part 05: Internal ERP ——

model Department {
  id          String       @id @default(cuid())
  code        String       @unique
  name        String
  description String?
  parentId    String?
  parent      Department?  @relation("DeptTree", fields: [parentId], references: [id], onDelete: SetNull)
  children    Department[] @relation("DeptTree")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  employees   Employee[]
  projects    ErpProject[]
  costCenter  String?

  @@index([parentId])
}

model Employee {
  id             String      @id @default(cuid())
  employeeCode   String      @unique
  userId         String?     @unique
  user           User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  departmentId   String?
  department     Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  fullName       String
  email          String
  phone          String?
  /// FULL_TIME | PART_TIME | CONTRACT | INTERN
  employmentType String      @default("FULL_TIME")
  jobTitle       String
  /// CEO | DIRECTOR | HR | FINANCE | SALES | MARKETING | SUPPORT | DEVELOPER | ENGINEER | AUDITOR | STAFF
  orgRole        String      @default("STAFF")
  /// ACTIVE | ON_LEAVE | TERMINATED
  status         String      @default("ACTIVE")
  hireDate       DateTime    @default(now())
  salaryCents    Int         @default(0)
  managerId      String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  attendance AttendanceRecord[]
  payrollLines PayrollLine[]

  @@index([departmentId])
  @@index([status])
  @@index([email])
  @@index([orgRole])
}

model LeaveRequest {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation("LeaveEmployee", fields: [userId], references: [id], onDelete: Cascade)
  /// ANNUAL | SICK | UNPAID | OTHER
  leaveType  String   @default("ANNUAL")
  startDate  DateTime
  endDate    DateTime
  reason     String?
  /// PENDING | APPROVED | REJECTED | CANCELLED
  status     String   @default("PENDING")
  approverId String?
  approver   User?    @relation("LeaveApprover", fields: [approverId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

model ErpProject {
  id           String      @id @default(cuid())
  projectCode  String      @unique
  name         String
  description  String?
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  /// PLANNING | ACTIVE | ON_HOLD | COMPLETED | CANCELLED
  status       String      @default("PLANNING")
  budgetCents  Int         @default(0)
  spentCents   Int         @default(0)
  startDate    DateTime?
  endDate      DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  members    ProjectMember[]
  tasks      ProjectTask[]
  milestones ProjectMilestone[]

  @@index([status])
  @@index([departmentId])
}

model ProjectMember {
  id        String     @id @default(cuid())
  projectId String
  project   ErpProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// LEAD | MEMBER | VIEWER
  role      String     @default("MEMBER")

  @@unique([projectId, userId])
}

model ProjectTask {
  id          String     @id @default(cuid())
  projectId   String
  project     ErpProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  description String?
  /// TODO | IN_PROGRESS | DONE | BLOCKED
  status      String     @default("TODO")
  assigneeId  String?
  assignee    User?      @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  dueDate     DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([projectId])
  @@index([status])
  @@index([assigneeId])
}

model FinanceEntry {
  id          String   @id @default(cuid())
  entryNumber String   @unique
  /// INCOME | EXPENSE | TRANSFER | ADJUSTMENT
  type        String
  category    String
  description String
  amountCents Int
  currency    String   @default("LKR")
  entryDate   DateTime @default(now())
  createdById String?
  createdBy   User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)
  reference   String?
  createdAt   DateTime @default(now())

  @@index([type])
  @@index([entryDate])
  @@index([category])
}

model Asset {
  id            String    @id @default(cuid())
  assetCode     String    @unique
  name          String
  category      String
  /// AVAILABLE | ASSIGNED | MAINTENANCE | RETIRED
  status        String    @default("AVAILABLE")
  location      String?
  purchaseCents   Int       @default(0)
  purchaseDate    DateTime?
  assignedTo      String?
  /// Useful life years for depreciation
  usefulLifeYears Int       @default(5)
  salvageCents    Int       @default(0)
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  maintenance AssetMaintenance[]

  @@index([status])
  @@index([category])
}

model InventoryItem {
  id            String   @id @default(cuid())
  sku           String   @unique
  name          String
  category      String
  quantity      Int      @default(0)
  reorderLevel  Int      @default(5)
  unitCostCents Int      @default(0)
  warehouseId   String?
  warehouse     Warehouse? @relation(fields: [warehouseId], references: [id], onDelete: SetNull)
  batchCode     String?
  expiresAt     DateTime?
  barcode       String?
  location      String?
  updatedAt     DateTime @updatedAt
  createdAt     DateTime @default(now())

  movements StockMovement[]

  @@index([category])
  @@index([warehouseId])
}

model WorkOrder {
  id          String    @id @default(cuid())
  workNumber  String    @unique
  title       String
  description String?
  /// OPEN | SCHEDULED | IN_PROGRESS | DONE | CANCELLED
  status      String    @default("OPEN")
  /// LOW | MEDIUM | HIGH | URGENT
  priority    String    @default("MEDIUM")
  assetCode     String?
  assigneeId    String?
  assignee      User?     @relation("WorkOrderAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  dueDate       DateTime?
  scheduledAt   DateTime?
  latitude      Float?
  longitude     Float?
  customerSign  String?
  serviceReport String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([status])
  @@index([assigneeId])
}

model StaffPermission {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission String
  createdAt  DateTime @default(now())

  @@unique([userId, permission])
  @@index([userId])
}

/// —— Part 05 expanded modules ——

model AttendanceRecord {
  id         String    @id @default(cuid())
  employeeId String
  employee   Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  userId     String?
  user       User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  workDate   DateTime
  checkIn    DateTime?
  checkOut   DateTime?
  /// PRESENT | ABSENT | LATE | HALF_DAY | REMOTE
  status     String    @default("PRESENT")
  notes      String?
  createdAt  DateTime  @default(now())

  @@index([employeeId])
  @@index([workDate])
  @@index([userId])
}

model PayrollRun {
  id          String       @id @default(cuid())
  runNumber   String       @unique
  periodLabel String
  /// DRAFT | APPROVED | PAID
  status      String       @default("DRAFT")
  totalCents  Int          @default(0)
  createdAt   DateTime     @default(now())
  lines       PayrollLine[]
}

model PayrollLine {
  id           String     @id @default(cuid())
  payrollRunId String
  payrollRun   PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  employeeId   String
  employee     Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  grossCents   Int
  deductionsCents Int     @default(0)
  netCents     Int
  notes        String?

  @@index([payrollRunId])
  @@index([employeeId])
}

model JobOpening {
  id          String   @id @default(cuid())
  title       String
  department  String?
  description String?
  /// OPEN | CLOSED | FILLED
  status      String   @default("OPEN")
  createdAt   DateTime @default(now())
  applications JobApplication[]
}

model JobApplication {
  id           String     @id @default(cuid())
  jobOpeningId String
  jobOpening   JobOpening @relation(fields: [jobOpeningId], references: [id], onDelete: Cascade)
  fullName     String
  email        String
  phone        String?
  resumeUrl    String?
  /// NEW | SCREENING | INTERVIEW | OFFER | HIRED | REJECTED
  status       String     @default("NEW")
  notes        String?
  createdAt    DateTime   @default(now())

  @@index([jobOpeningId])
  @@index([status])
}

model Vendor {
  id          String   @id @default(cuid())
  vendorCode  String   @unique
  name        String
  email       String?
  phone       String?
  address     String?
  category    String?
  ownerId     String?
  owner       User?    @relation("VendorOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  /// ACTIVE | INACTIVE | BLOCKED
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())
  purchaseOrders PurchaseOrder[]

  @@index([status])
}

model PurchaseOrder {
  id          String   @id @default(cuid())
  poNumber    String   @unique
  vendorId    String?
  vendor      Vendor?  @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  description String
  amountCents Int
  /// DRAFT | SUBMITTED | APPROVED | ORDERED | RECEIVED | CANCELLED
  status      String   @default("DRAFT")
  orderedAt   DateTime?
  createdAt   DateTime @default(now())

  @@index([vendorId])
  @@index([status])
}

model Warehouse {
  id        String          @id @default(cuid())
  code      String          @unique
  name      String
  location  String?
  createdAt DateTime        @default(now())
  items     InventoryItem[]
}

model StockMovement {
  id        String        @id @default(cuid())
  itemId    String
  item      InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  /// IN | OUT | ADJUST | TRANSFER
  type      String
  quantity  Int
  note      String?
  createdAt DateTime      @default(now())

  @@index([itemId])
  @@index([createdAt])
}

model Bom {
  id          String    @id @default(cuid())
  bomCode     String    @unique
  productName String
  description String?
  createdAt   DateTime  @default(now())
  lines       BomLine[]
  productionOrders ProductionOrder[]
}

model BomLine {
  id          String @id @default(cuid())
  bomId       String
  bom         Bom    @relation(fields: [bomId], references: [id], onDelete: Cascade)
  componentSku String
  quantity    Float  @default(1)
}

model ProductionOrder {
  id          String   @id @default(cuid())
  orderNumber String   @unique
  bomId       String?
  bom         Bom?     @relation(fields: [bomId], references: [id], onDelete: SetNull)
  productName String
  quantity    Int      @default(1)
  /// PLANNED | IN_PROGRESS | QC | DONE | CANCELLED
  status      String   @default("PLANNED")
  createdAt   DateTime @default(now())

  @@index([status])
}

model AssetMaintenance {
  id          String   @id @default(cuid())
  assetId     String
  asset       Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  title       String
  /// SCHEDULED | IN_PROGRESS | DONE
  status      String   @default("SCHEDULED")
  scheduledAt DateTime?
  costCents   Int      @default(0)
  notes       String?
  createdAt   DateTime @default(now())

  @@index([assetId])
  @@index([status])
}

model ServiceCatalogItem {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  category    String
  description String?
  slaHours    Int      @default(24)
  active      Boolean  @default(true)
}

model EsIncident {
  id          String   @id @default(cuid())
  incidentNumber String @unique
  title       String
  description String?
  /// INCIDENT | PROBLEM | CHANGE | REQUEST
  type        String   @default("INCIDENT")
  /// OPEN | IN_PROGRESS | RESOLVED | CLOSED
  status      String   @default("OPEN")
  priority    String   @default("MEDIUM")
  slaDueAt    DateTime?
  createdAt   DateTime @default(now())

  @@index([status])
  @@index([type])
}

model ProjectMilestone {
  id          String     @id @default(cuid())
  projectId   String
  project     ErpProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  dueDate     DateTime?
  /// PENDING | DONE
  status      String     @default("PENDING")
  createdAt   DateTime   @default(now())

  @@index([projectId])
}

model IotDevice {
  id          String   @id @default(cuid())
  deviceCode  String   @unique
  name        String
  location    String?
  /// ONLINE | OFFLINE | ALERT
  status      String   @default("ONLINE")
  lastSeenAt  DateTime?
  healthScore Int      @default(100)
  createdAt   DateTime @default(now())
  readings    IotReading[]

  @@index([status])
}

model IotReading {
  id        String    @id @default(cuid())
  deviceId  String
  device    IotDevice @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  metric    String
  value     Float
  unit      String?
  createdAt DateTime  @default(now())

  @@index([deviceId])
  @@index([createdAt])
}

model Document {
  id          String   @id @default(cuid())
  docNumber   String   @unique
  title       String
  category    String
  /// DRAFT | PENDING | APPROVED | ARCHIVED
  status      String   @default("DRAFT")
  version     Int      @default(1)
  fileUrl     String?
  uploaderId  String?
  uploader    User?    @relation("DocUploader", fields: [uploaderId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([status])
}

model InternalMessage {
  id        String   @id @default(cuid())
  senderId  String
  sender    User     @relation("MsgSender", fields: [senderId], references: [id], onDelete: Cascade)
  channel   String   @default("general")
  body      String
  createdAt DateTime @default(now())

  @@index([channel])
  @@index([createdAt])
}

model AiInsight {
  id        String   @id @default(cuid())
  title     String
  category  String
  summary   String
  payload   String?
  createdAt DateTime @default(now())

  @@index([category])
}

/// —— Part 05: Organization OS (multi-tenant ready) ——

model Organization {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  legalName   String?
  taxId       String?
  email       String?
  phone       String?
  address     String?
  country     String?  @default("Sri Lanka")
  /// ACTIVE | INACTIVE
  status      String   @default("ACTIVE")
  /// SaaS tenant flag — MernCrest is primary tenant
  isPrimary   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  branches Branch[]

  @@index([status])
}

model Branch {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  code           String
  name           String
  city           String?
  address        String?
  phone          String?
  /// ACTIVE | INACTIVE
  status         String       @default("ACTIVE")
  isHeadOffice   Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([status])
}

/// System-wide audit trail for ERP / CRM / Finance actions
model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actorEmail String?
  actorName  String?
  /// LOGIN | LOGOUT | CREATE | UPDATE | DELETE | APPROVE | REJECT | PAYMENT | INVENTORY | FINANCE | SETTINGS | EXPORT
  action     String
  module     String
  entityType String?
  entityId   String?
  summary    String
  metaJson   String?
  ip         String?
  createdAt  DateTime @default(now())

  @@index([module])
  @@index([action])
  @@index([actorId])
  @@index([createdAt])
  @@index([entityType, entityId])
}

/// Generic multi-level approval requests (leave, PO, expense, quote, project, invoice)
model ApprovalRequest {
  id           String    @id @default(cuid())
  requestNumber String   @unique
  /// LEAVE | PURCHASE | EXPENSE | QUOTATION | PROJECT | INVOICE | DOCUMENT | CUSTOM
  type         String
  title        String
  description  String?
  /// PENDING | APPROVED | REJECTED | CANCELLED
  status       String    @default("PENDING")
  requesterId  String
  approverId   String?
  referenceType String?
  referenceId  String?
  amountCents  Int?
  decidedAt    DateTime?
  decisionNote String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([type])
  @@index([status])
  @@index([requesterId])
  @@index([approverId])
  @@index([createdAt])
}

/// Chart of Accounts — foundation for GL / AR / AP
model ChartOfAccount {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  /// ASSET | LIABILITY | EQUITY | REVENUE | EXPENSE
  type        String
  parentCode  String?
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([type])
  @@index([active])
}

/// ESS salary slips generated from payroll runs
model SalarySlip {
  id           String   @id @default(cuid())
  slipNumber   String   @unique
  employeeId   String
  payrollRunId String?
  periodLabel  String
  grossCents   Int
  deductionsCents Int   @default(0)
  netCents     Int
  currency     String   @default("LKR")
  /// DRAFT | ISSUED | PAID
  status       String   @default("ISSUED")
  issuedAt     DateTime @default(now())
  metaJson     String?
  createdAt    DateTime @default(now())

  @@index([employeeId])
  @@index([payrollRunId])
  @@index([periodLabel])
}

/// —— Part 06: Platform Administration (database-driven config) ——

/// Key/value platform settings (company, branding, security, email, maintenance…)
model SystemSetting {
  id          String   @id @default(cuid())
  /// e.g. company.name | branding.primaryColor | security.sessionDays | maintenance.enabled
  key         String   @unique
  value       String
  /// STRING | NUMBER | BOOLEAN | JSON
  valueType   String   @default("STRING")
  group       String   @default("general")
  label       String?
  description String?
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([group])
}

model FeatureFlag {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  description String?
  enabled     Boolean  @default(false)
  /// STABLE | BETA | EXPERIMENTAL
  tier        String   @default("STABLE")
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([enabled])
  @@index([tier])
}

/// CMS pages for public website content (database-driven, not hardcoded)
model CmsPage {
  id              String    @id @default(cuid())
  slug            String    @unique
  title           String
  /// HOME | ABOUT | SERVICES | PORTFOLIO | PRICING | LEGAL | BLOG | CUSTOM
  pageType        String    @default("CUSTOM")
  locale          String    @default("en")
  excerpt         String?
  bodyHtml        String?
  heroTitle       String?
  heroSubtitle    String?
  heroImageUrl    String?
  seoTitle        String?
  seoDescription  String?
  /// DRAFT | PUBLISHED | ARCHIVED
  status          String    @default("DRAFT")
  publishedAt     DateTime?
  version         Int       @default(1)
  updatedById     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([pageType])
  @@index([status])
  @@index([locale])
}

model MediaAsset {
  id          String   @id @default(cuid())
  filename    String
  title       String?
  /// IMAGE | VIDEO | PDF | DOCUMENT | ICON | LOGO | BANNER | OTHER
  kind        String   @default("IMAGE")
  mimeType    String?
  url         String
  folder      String   @default("general")
  sizeBytes   Int?
  width       Int?
  height      Int?
  altText     String?
  uploadedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  @@index([kind])
  @@index([folder])
  @@index([createdAt])
}

/// Platform API keys for integrations / partners (not reseller Provider keys)
model PlatformApiKey {
  id          String    @id @default(cuid())
  name        String
  keyPrefix   String
  keyHash     String    @unique
  scopesJson  String?
  /// ACTIVE | REVOKED
  status      String    @default("ACTIVE")
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
}

model WebhookEndpoint {
  id          String   @id @default(cuid())
  name        String
  url         String
  /// ORDER | PAYMENT | TICKET | LEAD | ALL
  eventTypes  String   @default("ALL")
  secret      String?
  active      Boolean  @default(true)
  lastStatus  String?
  lastFiredAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([active])
}

model BackupRecord {
  id          String   @id @default(cuid())
  label       String
  /// MANUAL | SCHEDULED | SYSTEM
  type        String   @default("MANUAL")
  /// PENDING | COMPLETED | FAILED
  status      String   @default("PENDING")
  location    String?
  sizeBytes   Int?
  notes       String?
  createdById String?
  completedAt DateTime?
  createdAt   DateTime @default(now())

  @@index([status])
  @@index([createdAt])
}

model EmailTemplate {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  subject     String
  bodyHtml    String
  bodyText    String?
  /// en | ta | si
  locale      String   @default("en")
  active      Boolean  @default(true)
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([locale])
  @@index([active])
}
